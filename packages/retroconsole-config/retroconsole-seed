#!/usr/bin/env bash
# RetroConsole managed-home reconciler. OTA (pacman -Syu) only touches packaged
# files, never /home/retro — so this script is the path by which updated home
# defaults reach installed boxes. It runs after "Update System" and on every
# (non-live) boot via retroconsole-seed.service.
#
# Override policy (locked — by user-reachability, no stamp file):
#   * User-reachable from the on-screen UI (ES-DE settings -> es_settings.xml,
#     plus ROMs / savestates / scraped media / gamelists) -> NEVER touched.
#   * Not reachable (tool launchers, es_systems.xml, .bash_profile, foot.ini,
#     retroarch.cfg managed keys, system config) -> ALWAYS force-overwritten to
#     our value, every run.
#
# Idempotent: a second run is a no-op (same result, no errors). Every reconcile
# block is non-fatal — a seed error must never mark an update FAILED.
set -uo pipefail

LOG=/var/log/retroconsole-seed.log
SKEL=/usr/share/retroconsole/skel/home/retro
HOME_DIR=/home/retro

log() { echo ":: $*" | tee -a "${LOG}"; }

# Live media runs from a tmpfs overlay: there is no persistent /home to seed,
# and the squashfs already carries fresh defaults. Skip entirely.
if [[ -e /etc/retroconsole-live ]]; then
    exit 0
fi

if [[ ${EUID} -ne 0 ]]; then
    exec sudo "$0" "$@"
fi

log "=== RetroConsole seed started: $(date) ==="

# Nothing to do without a skel source or a target home (e.g. before first
# install). Exit cleanly rather than erroring.
if [[ ! -d ${SKEL} ]]; then
    log "skel ${SKEL} missing — nothing to reconcile"
    exit 0
fi
if [[ ! -d ${HOME_DIR} ]]; then
    log "home ${HOME_DIR} missing — nothing to reconcile"
    exit 0
fi

# ensure_kv_force <file> <key> <value>
# Force a "key = value" line: replace the line if "^key\s*=" is present, else
# append. awk avoids sed delimiter trouble when the value contains slashes
# (e.g. paths). Idempotent: re-running yields the same file.
ensure_kv_force() {
    local file=$1 key=$2 value=$3 line tmp
    line="${key} = \"${value}\""
    [[ -f ${file} ]] || return 0
    tmp=$(mktemp) || return 1
    if awk -v key="${key}" -v line="${line}" '
        $0 ~ "^" key "[[:space:]]*=" { print line; found=1; next }
        { print }
        END { if (!found) print line }
    ' "${file}" > "${tmp}"; then
        cat "${tmp}" > "${file}"
    fi
    rm -f "${tmp}"
}

# --- Managed FILES: force-overwrite from skel ----------------------------- #
# Tool launchers are root-owned 0755 (match profiledef.sh): the kiosk runs them
# from the ES-DE Tools menu, the user can't edit them from the on-screen UI.
if compgen -G "${SKEL}/ROMs/tools/*.sh" >/dev/null; then
    for f in "${SKEL}"/ROMs/tools/*.sh; do
        name=$(basename "${f}")
        if install -D -o root -g root -m 0755 "${f}" "${HOME_DIR}/ROMs/tools/${name}"; then
            log "tool launcher: ${name}"
        else
            log "WARN: failed to install tool launcher ${name}"
        fi
    done
fi

# Config files the user can't reach from the UI: retro:retro 0644.
for rel in \
    "ES-DE/custom_systems/es_systems.xml" \
    ".bash_profile" \
    ".config/foot/foot.ini"
do
    src="${SKEL}/${rel}"
    [[ -f ${src} ]] || continue
    if install -D -o retro -g retro -m 0644 "${src}" "${HOME_DIR}/${rel}"; then
        log "config file: ${rel}"
    else
        log "WARN: failed to install config file ${rel}"
    fi
done

# --- Bundled ES-DE systems list: force EMPTY (#62/#63) -------------------- #
# Root-cause fix for the create-system-directories ROM flood. ES-DE merges its
# ~190-system bundled es_systems.xml UNDER custom_systems, which only overrides
# by <name> — so ES-DE still "knows" ~190 systems and Utilities -> "Create/
# update system directories" floods /home/retro/ROMs with ~190 dirs (most 0755,
# not guest-writable). Overwriting the bundled file with an empty <systemList/>
# leaves the curated custom_systems as everything ES-DE knows, so that menu can
# only ever (re)create the curated dirs. The stub ships at a NEUTRAL path (a
# pacman file conflict would abort pacstrap); we force it onto the real bundled
# file every run, so it re-applies after a pacman -Syu reverts that file to
# stock. (Fallback if ES-DE ever errors on an empty list: ship the curated set
# in the stub instead and re-sync on ES-DE bumps — see #63.)
STUB=/usr/share/retroconsole/es-de/es_systems-empty.xml
ESDE_SYSTEMS=/usr/share/es-de/resources/systems/linux/es_systems.xml
if [[ ! -e ${ESDE_SYSTEMS} ]]; then
    # ES-DE moved the file (future version / non-standard layout): search for it.
    ESDE_SYSTEMS=$(find /usr/share/es-de/resources/systems -type f -name es_systems.xml 2>/dev/null | head -n1)
fi
if [[ -f ${STUB} && -n ${ESDE_SYSTEMS} && -e ${ESDE_SYSTEMS} ]]; then
    # install(1) -> root:root 0644, matching the package-owned bundled file.
    if install -Dm644 "${STUB}" "${ESDE_SYSTEMS}"; then
        log "bundled es_systems.xml emptied (custom_systems is sole source of truth)"
    else
        log "WARN: failed to empty bundled es_systems.xml at ${ESDE_SYSTEMS}"
    fi
else
    log "bundled es_systems.xml not found — skipping empty-stub apply (non-fatal)"
fi

# --- Curated ROM dirs: keep guest-writable; sweep empty extras (#62/#64) --- #
# A narrow, deliberate exception to "seed never touches ROMs": top-level dir
# modes/existence ONLY, never user content. The curated set is exactly what
# custom_systems defines — the same set ES-DE now knows (bundled list emptied
# above) — so the create-system-directories menu can only ever (re)create these.
ROMS_DIR="${HOME_DIR}/ROMs"
SYSTEMS_XML="${SKEL}/ES-DE/custom_systems/es_systems.xml"
if [[ -f ${SYSTEMS_XML} && -d ${ROMS_DIR} ]]; then
    mapfile -t CURATED < <(grep -oP '%ROMPATH%/\K[^<]+' "${SYSTEMS_XML}" | sort -u)
    declare -A CURATED_SET=()
    for name in "${CURATED[@]}"; do CURATED_SET["${name}"]=1; done

    # 1) Reconcile each curated dir to retro:retro 0777 — the directory itself,
    #    never recursing into user ROMs. Covers dirs the menu recreates and dirs
    #    for systems added via OTA. 'tools' is excluded: it holds root-owned
    #    launchers (managed above) and is veto'd from the Samba share, so it must
    #    NOT become guest-writable. Materializing a dir for a curated system with
    #    no ROMs yet (e.g. 'genesis', when only 'megadrive' ships) is harmless:
    #    empty, hidden in ES-DE until populated, and writable.
    for name in "${CURATED[@]}"; do
        [[ ${name} == tools ]] && continue
        dir="${ROMS_DIR}/${name}"
        # Never reconcile THROUGH a symlink: chown/chmod follow it (no -h), so a
        # symlinked curated dir (e.g. ROMs/nes -> /mnt/usb) would make an
        # arbitrary target world-writable + retro-owned on every boot. A symlink
        # already resolves in ES-DE; leave its target's mode/owner to the user.
        if [[ -L ${dir} ]]; then
            log "curated ROM dir is a symlink — left untouched: ${name}"
            continue
        fi
        if mkdir -p "${dir}" && chown retro:retro "${dir}" && chmod 0777 "${dir}"; then
            log "curated ROM dir reconciled: ${name} (retro:retro 0777)"
        else
            log "WARN: failed to reconcile curated ROM dir ${name}"
        fi
    done

    # 2) Sweep empty non-curated leftovers: a top-level ROMs/ subdir that is NOT
    #    curated and holds nothing but ES-DE's generated systeminfo.txt (or is
    #    empty). Any real content (a ROM, a subdir, any other file) -> keep, log,
    #    skip. Deleting systeminfo.txt then rmdir (not rm -rf) is the safety net:
    #    rmdir refuses if anything unexpected remains, so user ROMs can't be lost.
    for dir in "${ROMS_DIR}"/*/; do
        [[ -d ${dir} ]] || continue
        base=$(basename "${dir}")
        [[ -n ${CURATED_SET[${base}]:-} ]] && continue
        # Never sweep THROUGH a symlink: rm/rmdir would act on the link's target,
        # touching data outside ROMs/. (${dir%/} strips the glob's trailing slash,
        # which would otherwise make -L follow the link instead of testing it.)
        if [[ -L ${dir%/} ]]; then
            log "non-curated ROM dir is a symlink — kept (not swept): ${base}"
            continue
        fi
        if [[ -n $(find "${dir}" -mindepth 1 ! -name systeminfo.txt -print -quit 2>/dev/null) ]]; then
            log "non-curated ROM dir kept (has content): ${base}"
            continue
        fi
        rm -f "${dir}systeminfo.txt"
        if rmdir "${dir}" 2>/dev/null; then
            log "non-curated ROM dir swept (was empty): ${base}"
        else
            log "WARN: could not remove non-curated dir ${base} — keeping"
        fi
    done
else
    log "custom_systems/es_systems.xml or ROMs/ missing — skipping ROM dir reconcile"
fi

# --- Managed KEYS in retroarch.cfg: force to our value -------------------- #
# RetroArch re-saves the whole config on exit, so a managed key must be forced
# every run. es_settings.xml is user-reachable and is NEVER touched here.
RA_CFG="${HOME_DIR}/.config/retroarch/retroarch.cfg"
if [[ -f ${RA_CFG} ]]; then
    ensure_kv_force "${RA_CFG}" "joypad_autoconfig_dir" "/usr/share/libretro/autoconfig"
    # Force the in-game-menu combo onto already-installed boxes (M11/#18): the
    # airootfs value only reaches FRESH installs, so without this an OTA-upgraded
    # box keeps a retroarch.cfg that has no input_menu_toggle_gamepad_combo and
    # the menu stays keyboard-only. "9" = Down+Select (see retroarch.cfg for the
    # enum + version pin). video_driver is deliberately NOT managed here: we keep
    # RetroArch's gl/glsl default and must not revert an enthusiast who switched
    # to glcore for slang shaders (M11 locked decision #2).
    ensure_kv_force "${RA_CFG}" "input_menu_toggle_gamepad_combo" "9"
    # video_refresh_rate is intentionally NOT managed here: it is display-
    # dependent, so the in-session launcher (retroconsole-launch) sets it per
    # boot from the refresh cage is actually driving, falling back to the
    # airootfs default (50Hz) when it can't be read (#13/#14).
    chown retro:retro "${RA_CFG}" || log "WARN: failed to chown ${RA_CFG}"
    log "retroarch.cfg keys reconciled"
else
    log "retroarch.cfg absent — skipping managed keys"
fi

log "=== RetroConsole seed finished: $(date) ==="
exit 0
