# RetroConsole appliance configuration, packaged so fixes reach installed
# systems through "Update System" (pacman -Syu) instead of a reflash.
#
# Scope: system-level files only. Seeds under /home/retro (ES-DE settings,
# retroarch.cfg, foot.ini, ROM dirs) stay in the image's airootfs — they
# are runtime-mutable user state an upgrade must not clobber. The live-only
# installer (retroconsole-install + its sudoers grant) also stays airootfs.
#
# Bump pkgver (or pkgrel for a rebuild), run a build, then
# scripts/publish-repo.sh to ship an update.
pkgname=retroconsole-config
pkgver=1.0.0
pkgrel=10
pkgdesc="RetroConsole appliance configuration and session scripts"
arch=('any')
url="https://github.com/wiz4rd-de/RetroConsole"
license=('MIT')
# openssh: pulled over OTA for the field-debug sshd (B3/#15). wlr-randr: read
# the live output refresh in-session to pin RetroArch's audio clock to the panel
# (retroconsole-launch, #14). wireplumber: retroconsole-launch uses wpctl to pin
# the default sink to full volume (#13). Declared here so existing boxes get the
# binaries on the next "Update System".
#
# libretro-shaders-glsl/-slang (M11/#19, #20): the shader packs were originally
# listed ONLY in packages.x86_64, which seeds the ISO build (pacstrap) and nothing
# more. A `pacman -Syu` OTA upgrades installed packages and pulls new DEPENDENCIES,
# but never installs a brand-new package nothing depends on — so OTA-updated boxes
# got the shader alt-emulators (and the in-game shader browser) WITHOUT the shader
# files they point at: the tiers silently loaded no shader and Quick Menu -> Shaders
# was empty until the user ran the online updater. Depending on them here forces
# OTA to install the packs, matching a fresh flash. glsl is the active set the gl
# driver consumes; slang ships for enthusiasts who switch to glcore.
depends=('openssh' 'wlr-randr' 'wireplumber'
         'libretro-shaders-glsl' 'libretro-shaders-slang')
# Scriptlet enables retroconsole-seed.service on install/upgrade (A4/#11).
install=retroconsole-config.install
source=('retroconsole-session'
        'retroconsole-launch'
        'retroconsole-crt-launch'
        'retroconsole-update'
        'retroconsole-seed'
        'retroconsole-seed.service'
        'sudoers-retroconsole'
        '50-retroconsole-network.rules'
        '50-retroconsole-prefer-hdmi.conf'
        'vconsole.conf'
        'retrobit-genesis-saturn-8button.cfg'
        'es_systems-empty.xml')
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    install -Dm755 retroconsole-session "${pkgdir}/usr/local/bin/retroconsole-session"
    install -Dm755 retroconsole-launch "${pkgdir}/usr/local/bin/retroconsole-launch"
    # Shader-tier wrapper (#79): the ES-DE "RetroArch — <tier>" alt-emulators
    # invoke this with a preset path as $1; it forces that preset via --set-shader
    # unless the player saved a per-game preset (which wins). Replaces crt.cfg.
    install -Dm755 retroconsole-crt-launch "${pkgdir}/usr/local/bin/retroconsole-crt-launch"
    install -Dm755 retroconsole-update "${pkgdir}/usr/local/bin/retroconsole-update"
    install -Dm755 retroconsole-seed "${pkgdir}/usr/local/bin/retroconsole-seed"
    install -Dm644 retroconsole-seed.service "${pkgdir}/etc/systemd/system/retroconsole-seed.service"
    install -Dm440 sudoers-retroconsole "${pkgdir}/etc/sudoers.d/retroconsole"
    install -Dm644 50-retroconsole-network.rules "${pkgdir}/etc/polkit-1/rules.d/50-retroconsole-network.rules"
    install -Dm644 50-retroconsole-prefer-hdmi.conf "${pkgdir}/etc/wireplumber/wireplumber.conf.d/50-retroconsole-prefer-hdmi.conf"
    install -Dm644 vconsole.conf "${pkgdir}/etc/vconsole.conf"

    # RetroArch autoconfig profile for the Sega-lookalike pad (#46/#47). New
    # filename (not one retroarch-autoconfig-udev-git ships) so there is no
    # pacman file conflict; RetroArch matches by file CONTENT (VID/PID + exact
    # device name), not filename. OTA-delivered like every other managed file.
    install -Dm644 retrobit-genesis-saturn-8button.cfg \
        "${pkgdir}/usr/share/libretro/autoconfig/udev/retrobit-genesis-saturn-8button.cfg"

    # Empty bundled-systems stub (#62/#63). retroconsole-seed force-overwrites
    # ES-DE's ~190-system bundled es_systems.xml with this empty <systemList/>,
    # making custom_systems/es_systems.xml the SOLE source of truth — the root-
    # cause fix for the "Create/update system directories" ROM flood. Packaged to
    # a NEUTRAL path (NOT the emulationstation-de-owned bundled file) so pacstrap
    # never hits a file conflict; the seed copies it onto the real file at runtime
    # and re-applies it after every "Update System" reverts the bundled file to
    # stock. Same reasoning as the autoconfig profile above.
    install -Dm644 es_systems-empty.xml "${pkgdir}/usr/share/retroconsole/es-de/es_systems-empty.xml"

    # Managed-home seed payload, packaged to a NEUTRAL path (never /home — that
    # would abort pacstrap on a file conflict, the M3 dpad-hook lesson). The
    # skel/ tree is generated at build time (A2/#9) from the airootfs allowlist;
    # retroconsole-seed reads it from here. Preserve the relative structure;
    # tool launchers are executable (0755), config files are 0644.
    # skel/ is generated by build-aur-repo.sh next to this PKGBUILD ($startdir),
    # NOT a declared source=() entry, so makepkg never copies it into $srcdir —
    # read it from $startdir directly (a relative "skel" would silently miss it
    # and ship an empty skel: no tool launchers, no managed keys reach any box).
    if [[ -d ${startdir}/skel ]]; then
        while IFS= read -r -d '' f; do
            rel="${f#"${startdir}"/skel/}"
            if [[ ${f} == *.sh ]]; then
                install -Dm755 "${f}" "${pkgdir}/usr/share/retroconsole/skel/${rel}"
            else
                install -Dm644 "${f}" "${pkgdir}/usr/share/retroconsole/skel/${rel}"
            fi
        done < <(find "${startdir}/skel" -type f -print0)
    fi
}
