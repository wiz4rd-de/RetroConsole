#!/usr/bin/env bash
# RetroConsole kiosk session: ES-DE inside the cage Wayland compositor.
# Launched from ~/.bash_profile on tty1; getty respawns it if it exits.

# Escape hatch for GPUs the GLES renderer cannot drive: add
# "retroconsole.software" to the kernel command line.
if grep -qw 'retroconsole.software' /proc/cmdline; then
    export WLR_RENDERER=pixman
    export LIBGL_ALWAYS_SOFTWARE=1
fi

export XKB_DEFAULT_LAYOUT="${XKB_DEFAULT_LAYOUT:-de}"

# retroconsole-launch runs inside cage: it pins RetroArch's video_refresh_rate
# to the refresh cage is actually driving (kills the audio drift from a 50Hz
# panel vs RetroArch's assumed 60Hz, #13/#14), then exec's ES-DE.
exec cage -- /usr/local/bin/retroconsole-launch
