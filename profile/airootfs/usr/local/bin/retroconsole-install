#!/usr/bin/env bash
# RetroConsole installer.
#
# Runs automatically on tty1 of the live ISO. Picks the largest internal,
# non-removable disk and asks for a single confirmation. It then runs in one
# of two modes, chosen automatically from the partitions already on the disk:
#
#   fresh    - no RetroConsole layout found: wipe the whole disk, create the
#              partitions below, and seed /home from the live image.
#   preserve - a RetroConsole layout is found (rcsys + rcesp + rcuser): only
#              the system is reinstalled; the rcuser (/home) partition is kept,
#              so games and settings survive a reinstall/update.
#
# Disk layout (GPT, boots on both UEFI and legacy BIOS):
#   p1  1 MiB    BIOS boot partition (GRUB core.img)   name rcbios
#   p2  512 MiB  EFI system partition (FAT32)          name rcesp
#   p3  16 GiB   ext4 system root                      name rcsys
#   p4  rest     ext4 user data, mounted at /home      name rcuser
set -euo pipefail

SFS=/run/archiso/bootmnt/arch/x86_64/airootfs.sfs
KERNEL=/run/archiso/bootmnt/arch/boot/x86_64/vmlinuz-linux
MNT=/mnt
SYS_SIZE_MIB=16384                              # 16 GiB system partition
MIN_DISK_BYTES=$(( 24 * 1024 * 1024 * 1024 ))   # 24 GiB minimum disk (fresh installs)

die() {
    echo
    echo "ERROR: $*" >&2
    echo "Dropping to a shell. Type 'reboot' to restart." >&2
    exec bash -i
}

[[ -e /etc/retroconsole-live ]] || die "Not running from the RetroConsole live ISO; refusing to install."
[[ ${EUID} -eq 0 ]] || exec sudo "$0" "$@"
if [[ ! -r ${SFS} ]]; then
    # The installer boot entry sets copytoram=n; this only happens when
    # someone forces copytoram=y, which unmounts the boot medium.
    [[ -r /run/archiso/copytoram/airootfs.sfs ]] \
        && die "Booted with copytoram: the boot medium was unmounted. Reboot into the installer entry without copytoram."
    die "Cannot find ${SFS} (is the boot medium still attached?)"
fi
[[ -r ${KERNEL} ]] || die "Cannot find ${KERNEL}"

# --- Pick the target disk -------------------------------------------------

# The disk the live medium itself lives on must never be a target.
boot_src=$(findmnt -no SOURCE /run/archiso/bootmnt || true)
boot_disk=""
if [[ -n ${boot_src} && ${boot_src} == /dev/* ]]; then
    boot_disk=$(lsblk -no PKNAME "${boot_src}" 2>/dev/null | head -1 || true)
    [[ -z ${boot_disk} ]] && boot_disk=$(basename "${boot_src}")
fi

target=""
target_size=0
while read -r name size rm type; do
    [[ ${type} == disk ]] || continue
    [[ ${rm} -eq 0 ]] || continue                      # skip removable (USB sticks)
    [[ ${name} == "${boot_disk}" ]] && continue        # skip the live medium
    [[ ${name} == loop* || ${name} == sr* || ${name} == zram* ]] && continue
    if (( size > target_size )); then
        target=${name}
        target_size=${size}
    fi
done < <(lsblk -dbno NAME,SIZE,RM,TYPE)

[[ -n ${target} ]] || die "No suitable internal disk found."

disk=/dev/${target}
model=$(lsblk -dno MODEL "${disk}" | sed 's/^ *//;s/ *$//')
human_size=$(lsblk -dno SIZE "${disk}")

# --- Fresh vs preserve ----------------------------------------------------

# Echo the device path of the partition on ${disk} whose GPT name (PARTLABEL)
# is $1, or nothing. Scoped to ${disk} so a RetroConsole layout on some other
# disk can never flip the mode or be touched. Always returns 0 (callers test
# the output for emptiness), so it is safe under `set -e`.
part_by_label() {
    local want=$1 name plabel
    while read -r name plabel; do
        if [[ ${plabel} == "${want}" ]]; then
            echo "/dev/${name}"
            return 0
        fi
    done < <(lsblk -rno NAME,PARTLABEL "${disk}")
    return 0
}

udevadm settle
sys_part=$(part_by_label rcsys)
usr_part=$(part_by_label rcuser)
esp_part=$(part_by_label rcesp)

if [[ -n ${sys_part} && -n ${usr_part} && -n ${esp_part} ]]; then
    mode=preserve
else
    mode=fresh
    # A normal fresh disk has neither label; exactly one present means a
    # half-built or foreign RetroConsole layout we are about to discard.
    if [[ -n ${sys_part} || -n ${usr_part} ]]; then
        echo ":: Incomplete RetroConsole layout on ${disk}; performing a fresh install."
    fi
fi

if [[ ${mode} == fresh ]] && (( target_size < MIN_DISK_BYTES )); then
    die "Target disk ${disk} is only ${human_size}; RetroConsole needs at least 24 GiB."
fi

# --- The one confirmation -------------------------------------------------

clear
echo "==============================================="
echo "          RetroConsole Installer"
echo "==============================================="
echo
echo "  Target disk:  ${disk}"
echo "  Model:        ${model:-unknown}"
echo "  Size:         ${human_size}"
echo
if [[ ${mode} == preserve ]]; then
    echo "  Existing RetroConsole install detected."
    echo
    echo "  The system will be REINSTALLED."
    echo "  Your games and settings will be KEPT."
    echo
    prompt="Type YES (in capitals) to reinstall RetroConsole on ${disk} and keep your data: "
else
    echo "  ALL DATA ON THIS DISK WILL BE ERASED."
    echo
    prompt="Type YES (in capitals) to erase ${disk} and install RetroConsole: "
fi
read -rp "${prompt}" answer
if [[ ${answer} != YES ]]; then
    echo
    echo "Aborted. Nothing was changed."
    echo "Press Enter to reboot, or Ctrl+C for a shell."
    read -r
    systemctl reboot
    exit 0
fi

# --- Partition and format -------------------------------------------------
#
# Devices are resolved by GPT name (PARTLABEL) via part_by_label rather than
# by ${disk}p${n}/${disk}${n} arithmetic, so nvme (p-suffixed) and sd* disks
# are handled identically and preserve mode reuses the existing partitions.

if [[ ${mode} == preserve ]]; then
    echo
    echo ":: Reinstalling onto ${disk} (keeping the rcuser /home partition)..."
    esp=${esp_part}
    sys=${sys_part}
    usr=${usr_part}
    # Check the partition we are about to KEEP before destroying anything else,
    # so a corrupt user partition aborts with the rest of the disk still intact.
    # fsck exit codes are a bitmask: 0 = clean, 1 = minor errors auto-corrected
    # (e.g. a dirty journal), 2/3 = corrected + reboot advised; >=4 means errors
    # were left uncorrected and the data needs manual repair. (The bare call is
    # OR'd so a non-zero "corrected" status does not trip `set -e`.)
    fsck_rc=0
    fsck -p "${usr}" || fsck_rc=$?
    if (( fsck_rc >= 4 )); then
        die "User partition ${usr} (rcuser) needs repair (fsck exit ${fsck_rc}); aborting to protect your data."
    fi
    echo ":: Creating filesystems (rcuser is left untouched)..."
    mkfs.fat  -F 32 -n RCESP "${esp}"
    mkfs.ext4 -q -F  -L rcsys "${sys}"
else
    echo
    echo ":: Partitioning ${disk}..."
    sgdisk --zap-all "${disk}"
    sgdisk --new=1:0:+1MiB               --typecode=1:ef02 --change-name=1:rcbios "${disk}"
    sgdisk --new=2:0:+512MiB             --typecode=2:ef00 --change-name=2:rcesp  "${disk}"
    sgdisk --new=3:0:+${SYS_SIZE_MIB}MiB --typecode=3:8300 --change-name=3:rcsys  "${disk}"
    sgdisk --new=4:0:0                   --typecode=4:8300 --change-name=4:rcuser "${disk}"
    udevadm settle
    esp=$(part_by_label rcesp)
    sys=$(part_by_label rcsys)
    usr=$(part_by_label rcuser)
    [[ -b ${esp} && -b ${sys} && -b ${usr} ]] || die "Partition discovery failed on ${disk}."
    echo ":: Creating filesystems..."
    mkfs.fat  -F 32 -n RCESP  "${esp}"
    mkfs.ext4 -q -F  -L rcsys  "${sys}"
    mkfs.ext4 -q -F  -L rcuser "${usr}"
fi

udevadm settle
mount "${sys}" "${MNT}"
mkdir -p "${MNT}/boot/efi"
mount "${esp}" "${MNT}/boot/efi"

# --- Copy the system ------------------------------------------------------
#
# The squashfs carries the /home/retro skeleton (ROM folders, default configs,
# sample ROM) owned by uid/gid 1000. Where it ends up depends on the mode.

if [[ ${mode} == preserve ]]; then
    # NEVER mount rcuser before unsquashfs: "unsquashfs -f" force-overwrites and
    # would wipe the user's games and settings. Extract onto the system
    # partition first, then mount rcuser over /home and seed only the entries
    # the user does not already have (new ROM systems, new tools, ...). Existing
    # files are never clobbered (cp -n).
    echo ":: Copying system (this takes a few minutes)..."
    unsquashfs -f -d "${MNT}" "${SFS}"
    mv "${MNT}/home" "${MNT}/home.skel"
    mkdir -p "${MNT}/home"
    mount "${usr}" "${MNT}/home"
    echo ":: Keeping existing games and settings (adding any new defaults)..."
    cp -an "${MNT}/home.skel/." "${MNT}/home/"
    rm -rf "${MNT}/home.skel"
else
    # Fresh install: mount the empty rcuser partition at /home first, so the
    # skeleton lands directly on it with uid/gid 1000 ownership preserved.
    mkdir -p "${MNT}/home"
    mount "${usr}" "${MNT}/home"
    echo ":: Copying system (this takes a few minutes)..."
    unsquashfs -f -d "${MNT}" "${SFS}"
fi

# mkarchiso empties /boot inside the squashfs; restore kernel and microcode.
echo ":: Installing kernel..."
cp "${KERNEL}" "${MNT}/boot/vmlinuz-linux"
cp -f "${MNT}"/usr/lib/retroconsole/*-ucode.img "${MNT}/boot/" 2>/dev/null || true

echo ":: Generating fstab..."
genfstab -U "${MNT}" >> "${MNT}/etc/fstab"

# --- Strip live-only pieces ----------------------------------------------

echo ":: Converting live system to installed system..."
rm -f "${MNT}/etc/retroconsole-live"
rm -f "${MNT}/etc/mkinitcpio.conf.d/archiso.conf"
rm -f "${MNT}/usr/local/bin/retroconsole-install"
rm -f "${MNT}/etc/sudoers.d/retroconsole-live"

# Standard initramfs preset instead of the archiso one
cat > "${MNT}/etc/mkinitcpio.d/linux.preset" <<'EOF'
# mkinitcpio preset file for the 'linux' package
ALL_kver="/boot/vmlinuz-linux"
PRESETS=('default')
default_image="/boot/initramfs-linux.img"
EOF

# The live ISO keeps the pacman keyring on a tmpfs and re-initializes it each
# boot; an installed system wants a persistent keyring instead.
rm -f "${MNT}/etc/systemd/system/multi-user.target.wants/pacman-init.service"
rm -f "${MNT}/etc/systemd/system/pacman-init.service"
rm -f "${MNT}/etc/systemd/system/etc-pacman.d-gnupg.mount"

# --- Configure the installed system ----------------------------------------

arch-chroot "${MNT}" /bin/bash -e <<'CHROOT'
rm -f /etc/machine-id
systemd-machine-id-setup
mkinitcpio -P
pacman-key --init
pacman-key --populate archlinux
CHROOT

# --- Bootloader: both firmware paths, unconditionally ----------------------

echo ":: Installing bootloader (BIOS + UEFI)..."
arch-chroot "${MNT}" grub-install --target=i386-pc "${disk}"
arch-chroot "${MNT}" grub-install --target=x86_64-efi --efi-directory=/boot/efi \
    --bootloader-id=RetroConsole --removable --no-nvram
if [[ -d /sys/firmware/efi ]]; then
    # Booted via UEFI: also register a proper NVRAM boot entry.
    arch-chroot "${MNT}" grub-install --target=x86_64-efi --efi-directory=/boot/efi \
        --bootloader-id=RetroConsole
fi
arch-chroot "${MNT}" grub-mkconfig -o /boot/grub/grub.cfg

# --- Done -------------------------------------------------------------------

umount -R "${MNT}"

echo
echo "==============================================="
echo "  Installation complete."
echo "  Remove the USB stick, then press Enter to"
echo "  reboot into RetroConsole."
echo "==============================================="
read -r
systemctl reboot
